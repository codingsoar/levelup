# Nginx 설정 예시 (Ubuntu Server)
# 위치: /etc/nginx/sites-available/starquest
# (이후 ln -s /etc/nginx/sites-available/starquest /etc/nginx/sites-enabled/ 명령으로 활성화)

server {
    listen 80;
    server_name _; # 실제 도메인이 있다면 도메인 이름으로 변경 (예: starquest.hs.kr)

    root /var/www/starquest/dist; # React 빌드 파일 경로
    index index.html;

    # React 라우팅을 위한 설정 (SPA 최적화)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # /api 경로로 들어오는 요청을 Node.js 서버(포트 3000)로 포워딩
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        
        # 클라이언트의 실제 IP 전달
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
